# ─────────────────────────────────────────────────────────────
# Firebase — get from Firebase Console > Project Settings
# ─────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ─────────────────────────────────────────────────────────────
# Cloudinary — get from Cloudinary Dashboard
# ─────────────────────────────────────────────────────────────
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ─────────────────────────────────────────────────────────────
# Midtrans — VITE_ prefix = safe for browser (client key only)
# Get from: Midtrans Dashboard > Settings > Access Keys
# ─────────────────────────────────────────────────────────────
VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx
VITE_MIDTRANS_IS_PRODUCTION=false

# ─────────────────────────────────────────────────────────────
# Midtrans Server Key — NO VITE_ prefix = backend only (Vercel)
# Set this in Vercel Dashboard > Project > Settings > Environment Variables
# NEVER expose this in the browser
# ─────────────────────────────────────────────────────────────
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false
